PORT=3000
NODE_ENV=development

# Persistencia SQLite (recomendado en produccion)
SQLITE_STORAGE=./database/kyrbi.sqlite
# Alternativa equivalente:
# DATABASE_URL=sqlite:./database/kyrbi.sqlite

# Seguridad
JWT_SECRET=tu_super_secreto_aqui_cambialo_en_produccion

# Base de Datos (Opcional si usas SQLite)
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=password
# DB_NAME=kyrbi

# OAuth Credenciales
# Google: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook: https://developers.facebook.com/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft: https://portal.azure.com/
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Configuración CORS
CORS_ORIGIN=*
PUBLIC_BACKEND_URL=http://localhost:3000
PUBLIC_FRONTEND_URL=http://localhost:3000

# Si es "true", habilita chat para invitados.
# En produccion debe mantenerse en "false" para requerir cuenta.
ALLOW_PUBLIC_CHAT=false
MAX_MESSAGE_LENGTH=1200
MAX_REPLY_WORDS=260
MAX_REPLY_CHARS=2200
MAX_REPLY_BULLETS=5
APP_VERSION=1.0.0
RELEASE_DATE=2026-03-03
